{
    "app_title": "Wine Classification App",
    "app_version": 1.0,

    "data_folder_prefix": "data_process",

    "cv_models": {
        "logistic_regression": {},
        "decision_tree": {},
        "random_forest": {
            "n_estimators": 200
        },
        "knn": {
            "n_neighbors": 3
        }
    },

    "grid_search_models": {
        "logistic_regression": {
            "param_grid": {
                "solver": ["lbfgs", "liblinear"],
                "C": [0.1, 1, 10, 100]
            }
        },
        "decision_tree": {
            "param_grid": {
                "max_depth": [null, 5, 10, 20]
            }
        },
        "random_forest": {
            "param_grid": {
                "n_estimators": [50, 100, 200]
            }
        },
        "knn": {
            "param_grid": {
                "n_neighbors": [3, 5, 10]
            }
        }
    }
}
